"" jscontroller="hNviFe" data-sfc-root="c" jsuid="QYZ3Od_y" data-sfc-cb="" data-complete="true" data-sae="" style="">pedido.unidades<!--TgQPHd|[]--></code>).<span jsuid="QYZ3Od_z" class="txxDge notranslate" jsaction="rcuQ6b:&amp;QYZ3Od_z|npT2md" jscontroller="udAs2b" data-sfc-root="c" data-wiz-uids="QYZ3Od_10,QYZ3Od_11" data-sfc-cb="" data-complete="true" data-processed="true"><span class="vKEkVd" data-animation-atomic="" data-wiz-attrbind="class=QYZ3Od_z/TKHnVd" data-sae="" style=""><span aria-hidden="true">&nbsp;</span><!--qkimaf QYZ3Od_z/HugV6--><!--cqw1tb QYZ3Od_z/HugV6--><button jsuid="QYZ3Od_11" tabindex="0" data-amic="true" data-icl-uuid="2114a40d-1e7f-403e-a2dd-b9888432a18c" aria-label="Ver enlaces relacionados" class="rBl3me" jsaction="click:&amp;QYZ3Od_z|S9kKve;mouseenter:&amp;QYZ3Od_z|sbHm2b;mouseleave:&amp;QYZ3Od_z|Tx5Rb" data-wiz-attrbind="disabled=QYZ3Od_z/C5gNJc;aria-label=QYZ3Od_z/bOjMyf;class=QYZ3Od_z/UpSNec" data-ved="2ahUKEwipvZDUsZ-UAxXXywIHHWv1IgQQye0OegYIAQgBEAE" data-hveid="CAEIARAB"><span class="wiMplc ofC0Ud"><svg style="margin-top: 3px;" fill="currentColor" width="12px" height="12px" focusable="false" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z"></path></svg></span></button></span><!--TgQPHd|[[null,null,&quot;2114a40d-1e7f-403e-a2dd-b9888432a18c&quot;,null,null,0,0,&quot;&quot;,&quot;&quot;,0,null,null,0]]--></span><!--TgQPHd|[]--></div><div class="n6owBd awi2gc" data-sfc-cp="" jsaction="" jscontroller="TDBkbc" data-sfc-root="c" jsuid="QYZ3Od_12" data-sfc-cb="" data-hveid="CAEIAhAA" data-complete="true" data-processed="true">Para solucionarlo, debes usar los métodos de extracción de <code dir="ltr" class="KDcb0c" jsaction="" jscontroller="hNviFe" data-sfc-root="c" jsuid="QYZ3Od_13" data-sfc-cb="" data-complete="true" data-sae="" style="">Row<!--TgQPHd|[]--></code> indicando el tipo y la posición del índice (0, 1, 2...).<span jsuid="QYZ3Od_14" class="txxDge notranslate" jsaction="rcuQ6b:&amp;QYZ3Od_14|npT2md" jscontroller="udAs2b" data-sfc-root="c" data-wiz-uids="QYZ3Od_15,QYZ3Od_16" data-sfc-cb="" data-complete="true" data-processed="true"><span class="vKEkVd" data-animation-atomic="" data-wiz-attrbind="class=QYZ3Od_14/TKHnVd" data-sae="" style=""><span aria-hidden="true">&nbsp;</span><!--qkimaf QYZ3Od_14/HugV6--><!--cqw1tb QYZ3Od_14/HugV6--><button jsuid="QYZ3Od_16" tabindex="0" data-amic="true" data-icl-uuid="35239133-fbc8-46fc-89b5-d0709f495bcd" aria-label="Ver enlaces relacionados" class="rBl3me" jsaction="click:&amp;QYZ3Od_14|S9kKve;mouseenter:&amp;QYZ3Od_14|sbHm2b;mouseleave:&amp;QYZ3Od_14|Tx5Rb" data-wiz-attrbind="disabled=QYZ3Od_14/C5gNJc;aria-label=QYZ3Od_14/bOjMyf;class=QYZ3Od_14/UpSNec" data-ved="2ahUKEwipvZDUsZ-UAxXXywIHHWv1IgQQye0OegYIAQgCEAE" data-hveid="CAEIAhAB"><span class="wiMplc ofC0Ud"><svg style="margin-top: 3px;" fill="currentColor" width="12px" height="12px" focusable="false" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z"></path></svg></span></button></span><!--TgQPHd|[[null,null,&quot;35239133-fbc8-46fc-89b5-d0709f495bcd&quot;,null,null,0,0,&quot;&quot;,&quot;&quot;,0,null,null,0]]--></span><!--TgQPHd|[]--></div><div class="n6owBd awi2gc" data-sfc-cp="" jsaction="" jscontroller="TDBkbc" data-sfc-root="c" jsuid="QYZ3Od_17" data-sfc-cb="" data-hveid="CAEIAxAA" data-complete="true" data-processed="true">Asumiendo que tu objeto se llama <code dir="ltr" class="KDcb0c" jsaction="" jscontroller="hNviFe" data-sfc-root="c" jsuid="QYZ3Od_18" data-sfc-cb="" data-complete="true" data-sae="" style="">pedido<!--TgQPHd|[]--></code>, reemplaza la extracción de datos por este bloque:<span jsuid="QYZ3Od_19" class="txxDge notranslate" jsaction="rcuQ6b:&amp;QYZ3Od_19|npT2md" jscontroller="udAs2b" data-sfc-root="c" data-wiz-uids="QYZ3Od_1a,QYZ3Od_1b" data-sfc-cb="" data-complete="true" data-processed="true"><span class="vKEkVd" data-animation-atomic="" data-wiz-attrbind="class=QYZ3Od_19/TKHnVd" data-sae="" style=""><span aria-hidden="true">&nbsp;</span><!--qkimaf QYZ3Od_19/HugV6--><!--cqw1tb QYZ3Od_19/HugV6--><button jsuid="QYZ3Od_1b" tabindex="0" data-amic="true" data-icl-uuid="8c8c2a7b-6154-4228-b180-a2dd24fe3128" aria-label="Ver enlaces relacionados" class="rBl3me" jsaction="click:&amp;QYZ3Od_19|S9kKve;mouseenter:&amp;QYZ3Od_19|sbHm2b;mouseleave:&amp;QYZ3Od_19|Tx5Rb" data-wiz-attrbind="disabled=QYZ3Od_19/C5gNJc;aria-label=QYZ3Od_19/bOjMyf;class=QYZ3Od_19/UpSNec" data-ved="2ahUKEwipvZDUsZ-UAxXXywIHHWv1IgQQye0OegYIAQgDEAE" data-hveid="CAEIAxAB"><span class="wiMplc ofC0Ud"><svg style="margin-top: 3px;" fill="currentColor" width="12px" height="12px" focusable="false" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z"></path></svg></span></button></span><!--TgQPHd|[[null,null,&quot;8c8c2a7b-6154-4228-b180-a2dd24fe3128&quot;,null,null,0,0,&quot;&quot;,&quot;&quot;,0,null,null,0]]--></span><!--TgQPHd|[]--></div><div class="Fsg96" data-sfc-cp="" jsaction="rcuQ6b:&amp;QYZ3Od_1c|npT2md" jscontroller="KHhJQ" data-sfc-root="c" jsuid="QYZ3Od_1c" data-sfc-cb="" data-complete="true" data-processed="true"><!--TgQPHd|[]--></div><div class="r1PmQe" jsaction="" jscontroller="HP6Sjf" data-sfc-root="c" jsuid="QYZ3Od_1d" data-wiz-uids="QYZ3Od_1f,QYZ3Od_1e" data-sfc-cb="" data-hveid="CAEIBBAA" data-complete="true" data-processed="true"><div data-processed="true"><div class="pHpOfb" data-animation-atomic="" data-sae="" style=""><div class="z0e9Qd"><div class="vVRw1d">scala</div></div><div class="pCTyYe" dir="ltr"><pre><code jsuid="QYZ3Od_1f"><span class="ClTQqc">// Forma correcta de extraer datos de un objeto Row en Scala</span><span class="undefined">
</span><span class="mexSqb">val</span><span class="undefined"> idPedido       = pedido.getAs[Int](</span><span class="CS0cqb">"idPedido"</span><span class="undefined">)
</span><span class="mexSqb">val</span><span class="undefined"> cliente        = pedido.getAs[String](</span><span class="CS0cqb">"cliente"</span><span class="undefined">)
</span><span class="mexSqb">val</span><span class="undefined"> canal          = pedido.getAs[String](</span><span class="CS0cqb">"canal"</span><span class="undefined">)
</span><span class="mexSqb">val</span><span class="undefined"> producto       = pedido.getAs[String](</span><span class="CS0cqb">"producto"</span><span class="undefined">)
</span><span class="mexSqb">val</span><span class="undefined"> unidades       = pedido.getAs[Int](</span><span class="CS0cqb">"unidades"</span><span class="undefined">)
</span><span class="mexSqb">val</span><span class="undefined"> precioUnitario = pedido.getAs[Double](</span><span class="CS0cqb">"precioUnitario"</span><span class="undefined">)
