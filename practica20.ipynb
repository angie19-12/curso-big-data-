</span><span class="ClTQqc">// 1. Filtrar usando la sintaxis correcta para DataFrames</span><span class="undefined">
</span><span class="mexSqb">val</span><span class="undefined"> pedidosAltoValor = pipelineFinalPedidos.filter(col(</span><span class="CS0cqb">"segmentoPedido"</span><span class="undefined">) === </span><span class="CS0cqb">"ALTO_VALOR"</span><span class="undefined">)

</span><span class="ClTQqc">// 2. Agrupar y agregar (ya no necesitas el .toDF())</span><span class="undefined">
