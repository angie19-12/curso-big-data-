&quot;)\n\n&quot;,0],[&quot;// 3. Convertimos a DATAFRAME para agrupar (Velocidad y optimización)&quot;,5],[&quot;\n&quot;,0],[&quot;val&quot;,3],[&quot; dfImportePorCiudad \u003d dsAltoValor.toDF()\n  .groupBy(&quot;,0],[&quot;\&quot;ciudad\&quot;&quot;,4],[&quot;)\n  .agg(\n    sum(&quot;,0],[&quot;\&quot;importeTotal\&quot;&quot;,4],[&quot;).alias(&quot;,0],[&quot;\&quot;importe_total_alto_valor\&quot;&quot;,4],[&quot;)\n  )\n  .orderBy(desc(&quot;,0],[&quot;\&quot;importe_total_alto_valor\&quot;&quot;,4],[&quot;))\n\n&quot;,0],[&quot;// 4. Mostramos el resultado final&quot;,5],[&quot;\ndfImportePorCiudad.show(&quot;,0],[&quot;false&quot;,3],[&quot;)\n&quot;,0]]]]--></div><div class="Fsg96" data-sfc-cp="" jsaction="rcuQ6b:&amp;wYoLIc_z|npT2md" jscontroller="KHhJQ" data-sfc-root="c" jsuid="wYoLIc_z" data-sfc-cb="" data-complete="true" data-processed="true"><!--TgQPHd|[]--></div><div class="otQkpb" aria-level="3" role="heading" data-animation-nesting="" data-sfc-cp="" jsaction="" jscontroller="a7qCn" data-sfc-root="c" jsuid="wYoLIc_10" data-sfc-cb="" data-processed="true" data-sae="" data-complete="true" style="">💡 ¿Qué acabamos de hacer aquí?<span jsuid="wYoLIc_11" class="txxDge notranslate" jsaction="rcuQ6b:&amp;wYoLIc_11|npT2md" jscontroller="udAs2b" data-sfc-root="c" data-wiz-uids="wYoLIc_12,wYoLIc_13" data-sfc-cb="" data-complete="true"><span class="vKEkVd" data-animation-atomic="" data-wiz-attrbind="class=wYoLIc_11/TKHnVd" data-sae="" style=""><span aria-hidden="true">&nbsp;</span><!--qkimaf wYoLIc_11/HugV6--><!--cqw1tb wYoLIc_11/HugV6--><button jsuid="wYoLIc_13" tabindex="0" data-amic="true" data-icl-uuid="6f1e338f-9edc-47da-9702-a9d91793a8c0" aria-label="Ver enlaces relacionados" class="rBl3me" jsaction="click:&amp;wYoLIc_11|S9kKve;mouseenter:&amp;wYoLIc_11|sbHm2b;mouseleave:&amp;wYoLIc_11|Tx5Rb" data-wiz-attrbind="disabled=wYoLIc_11/C5gNJc;aria-label=wYoLIc_11/bOjMyf;class=wYoLIc_11/UpSNec" data-ved="2ahUKEwjU9d3ivJ-UAxU7UaQEHYVnFq8Qye0OegYIAQgEEAA" data-h