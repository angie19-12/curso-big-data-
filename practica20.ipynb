x|npT2md" jscontroller="udAs2b" data-sfc-root="c" data-wiz-uids="tpQP2c_y,tpQP2c_z" data-sfc-cb="" data-complete="true" data-processed="true"><span class="vKEkVd" data-animation-atomic="" data-wiz-attrbind="class=tpQP2c_x/TKHnVd" data-sae="" style=""><span aria-hidden="true">&nbsp;</span><!--qkimaf tpQP2c_x/HugV6--><!--cqw1tb tpQP2c_x/HugV6--><button jsuid="tpQP2c_z" tabindex="0" data-amic="true" data-icl-uuid="4b97fc0f-740e-4d54-ac55-35c5bf3eb1bc" aria-label="Ver enlaces relacionados" class="rBl3me" jsaction="click:&amp;tpQP2c_x|S9kKve;mouseenter:&amp;tpQP2c_x|sbHm2b;mouseleave:&amp;tpQP2c_x|Tx5Rb" data-wiz-attrbind="disabled=tpQP2c_x/C5gNJc;aria-label=tpQP2c_x/bOjMyf;class=tpQP2c_x/UpSNec" data-ved="2ahUKEwj6r8TisZ-UAxVE7AIHHQxFAt8Qye0OegYIAQgBEAE" data-hveid="CAEIARAB"><span class="wiMplc ofC0Ud"><svg style="margin-top: 3px;" fill="currentColor" width="12px" height="12px" focusable="false" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z"></path></svg></span></button></span><!--TgQPHd|[[null,null,&quot;4b97fc0f-740e-4d54-ac55-35c5bf3eb1bc&quot;,null,null,0,0,&quot;&quot;,&quot;&quot;,0,null,null,0]]--></span><!--TgQPHd|[]--></div><div class="n6owBd awi2gc" data-sfc-cp="" jsaction="" jscontroller="TDBkbc" data-sfc-root="c" jsuid="tpQP2c_10" data-sfc-cb="" data-hveid="CAEIAhAA" data-complete="true" data-processed="true">Copia y ejecuta este bloque completo en una celda nueva:<span jsuid="tpQP2c_11" class="txxDge notranslate" jsaction="rcuQ6b:&amp;tpQP2c_11|npT2md" jscontroller="udAs2b" data-sfc-root="c" data-wiz-uids="tpQP2c_12,tpQP2c_13" data-sfc-cb="" data-complete="true" data-processed="true"><span class="vKEkVd" data-animation-atomic="" data-wiz-attrbind="class=tpQP2c_11/TKHnVd" data-sae="" style=""><span aria-hidden="true">&nbsp;</span><!--qkimaf tpQP2c_11/HugV6--><!--cqw1tb tpQP2c_11/HugV6--><button jsuid="tpQP2c_13" tabindex="0" data-amic="true" data-icl-uuid="10d17c9b-5378-46eb-9409-b342c1e2f6cf" aria-label="Ver enlaces relacionados" class="rBl3me" jsaction="click:&amp;tpQP2c_11|S9kKve;mouseenter:&amp;tpQP2c_11|sbHm2b;mouseleave:&amp;tpQP2c_11|Tx5Rb" data-wiz-attrbind="disabled=tpQP2c_11/C5gNJc;aria-label=tpQP2c_11/bOjMyf;class=tpQP2c_11/UpSNec" data-ved="2ahUKEwj6r8TisZ-UAxVE7AIHHQxFAt8Qye0OegYIAQgCEAE" data-hveid="CAEIAhAB"><span class="wiMplc ofC0Ud"><svg style="margin-top: 3px;" fill="currentColor" width="12px" height="12px" focusable="false" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z"></path></svg></span></button></span><!--TgQPHd|[[null,null,&quot;10d17c9b-5378-46eb-9409-b342c1e2f6cf&quot;,null,null,0,0,&quot;&quot;,&quot;&quot;,0,null,null,0]]--></span><!--TgQPHd|[]--></div><div class="Fsg96" data-sfc-cp="" jsaction="rcuQ6b:&amp;tpQP2c_14|npT2md" jscontroller="KHhJQ" data-sfc-root="c" jsuid="tpQP2c_14" data-sfc-cb="" data-complete="true" data-processed="true"><!--TgQPHd|[]--></div><div class="r1PmQe" jsaction="" jscontroller="HP6Sjf" data-sfc-root="c" jsuid="tpQP2c_15" data-wiz-uids="tpQP2c_17,tpQP2c_16" data-sfc-cb="" data-hveid="CAEIAxAA" data-complete="true" data-processed="true"><div data-processed="true"><div class="pHpOfb" data-animation-atomic="" data-sae="" style=""><div class="z0e9Qd"><div class="vVRw1d">scala</div></div><div class="pCTyYe" dir="ltr"><pre><code jsuid="tpQP2c_17"><span class="mexSqb">import</span><span class="undefined"> spark.implicits._

</span><span class="ClTQqc">// 1. Define la estructura de entrada</span><span class="undefined">
</span><span class="mexSqb">case</span><span class="undefined"> </span><span class="mexSqb">class</span><span class="undefined"> VentaOnline(
  idPedido: Int, 
  cliente: String, 
  canal: String, 
  producto: String, 
  unidades: Int, 
  precioUnitario: Double, 
  ciudad: String
)

</span><span class="ClTQqc">// 2. Define la estructura de salida esperada</span><span class="undefined">
</span><span class="mexSqb">case</span><span class="undefined"> </span><span class="mexSqb">class</span><span class="undefined"> VentaOnlineProcesada(
  idPedido: Int,
  cliente: String,
  canal: String,
  producto: String,
  unidades: Int,
  precioUnitario: Double,
  ciudad: String,
  importeTotal: Double,
  segmentoPedido: String
)

</span><span class="ClTQqc">// 3. Convierte el DataFrame filtrado a un Dataset tipado</span><span class="undefined">
</span><span class="mexSqb">val</span><span class="undefined"> dsTipado = dsPedidosValidos.as[VentaOnline]

</span><span class="ClTQqc">// 4. Procesa fila por fila aplicando la lógica de negocio</span><span class="undefined">
</span><span class="mexSqb">val</span><span class="undefined"> dsPedidosProcesados = dsTipado.map { pedido =&gt;
  </span><span class="mexSqb">val</span><span class="undefined"> importeTotal = pedido.unidades * pedido.precioUnitario
  
  </span><span class="ClTQqc">// Lógica para determinar el segmento según los datos de tu imagen</span><span class="undefined">
  </span><span class="mexSqb">val</span><span class="undefined"> segmento = </span><span class="mexSqb">if</span><span class="undefined"> (importeTotal &gt; </span><span class="tnfcCf">500</span><span class="undefined">) {
    </span><span class="CS0cqb">"ALTO_VALOR"</span><span class="undefined">
  } </span><span class="mexSqb">else</span><span class="undefined"> </span><span class="mexSqb">if</span><span class="undefined"> (importeTotal &gt;= </span><span class="tnfcCf">150</span><span class="undefined">) {
    </span><span class="CS0cqb">"VALOR_MEDIO"</span><span class="undefined">
  } </span><span class="mexSqb">else</span><span class="undefined"> {
    </span><span class="CS0cqb">"BAJO_VALOR"</span><span class="undefined">
  }

  VentaOnlineProcesada(
    pedido.idPedido,
    pedido.cliente,
    pedido.canal,
    pedido.producto,
    pedido.unidades,
    pedido.precioUnitario,
    pedido.ciudad,
    importeTotal,
    segmento
  )
}

</span><span class="ClTQqc">// 5. Imprime el resultado final</span><span class="undefined">
