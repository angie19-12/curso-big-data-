</span></code></pre></div></div><div class="LIBz9e" data-animation-atomic="" data-sae="" style=""><div class="P8PNlb">Usa el código con precaución.</div><span jsuid="kXIFob_1c" jsaction="action:&amp;kXIFob_1b|VTVhdd" data-ved="2ahUKEwju04jps5-UAxWIzAIHHbTVOZMQopQPegYIAQgEEAE"><div jsuid="kXIFob_1e" data-sfc-cp="" jsaction="" jscontroller="cXTEid" data-sfc-root="c" data-sfc-cb="" data-ved="2ahUKEwju04jps5-UAxWIzAIHHbTVOZMQh9gSegYIAQgEEAI" data-complete="true"><button jsuid="kXIFob_1f" class="FTsWP RmjGdc IsqrXb" id="" aria-label="Copiar texto del código en el portapapeles." data-sfc-cp="" jsaction="pointerdown:&amp;kXIFob_1f|FEiYhc;pointerup:&amp;kXIFob_1f|mF5Elf;pointerenter:&amp;kXIFob_1f|EX0mI;pointerleave:&amp;kXIFob_1f|vpvbp;pointercancel:&amp;kXIFob_1f|xyn4sd;contextmenu:&amp;kXIFob_1f|i2ZJ6;click:&amp;kXIFob_1f|h5M12e;" jscontroller="h6yBLd" data-sfc-root="c" data-sfc-cb="KjsqPd=&amp;kXIFob_1e:UEmoBd" data-complete="true"><span class="XjoK4b kkxvEb" jsaction="" jscontroller="bJ5zY" data-sfc-root="c" jsuid="kXIFob_1g" data-sfc-cb="" data-complete="true"><!--TgQPHd|[]--></span><span jsuid="kXIFob_1h" class="UTNHae" jsaction="QBlI0e:&amp;kXIFob_1h|JwG8nd;BTifte:&amp;kXIFob_1h|ie0cXb;nqgE9d:&amp;kXIFob_1h|LZznfb;fHTtBd:&amp;kXIFob_1h|i8hBpd;" jscontroller="MAxPne" data-sfc-root="c" data-sfc-cb="" data-complete="true"><!--TgQPHd|[{&quot;u&quot;:0},false]--></span><span class="I36Cje" aria-hidden="true"><!--qkimaf kXIFob_1b/HugV6--><svg aria-hidden="true" class="MSS8xf" fill="currentColor" height="18px" viewBox="0 -960 960 960" width="18px"><path d="M360-240q-33 0-56.5-23.5T280-320v-480q0-33 23.5-56.5T360-880h360q33 0 56.5 23.5T800-800v480q0 33-23.5 56.5T720-240H360Zm0-80h360v-480H360v480ZM200-80q-33 0-56.5-23.5T120-160v-560h80v560h440v80H200Zm160-240v-480 480Z"></path></svg><!--cqw1tb kXIFob_1b/HugV6--></span><div class="ypuoue"></div><!--TgQPHd|[false]--></button><!--TgQPHd|[false]--></div></span></div></div><!--TgQPHd|[[&quot;scala&quot;,&quot;import org.apache.s