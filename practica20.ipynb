its._\n\n// 1. Define la estructura de entrada\ncase class VentaOnline(\n  idPedido: Int, \n  cliente: String, \n  canal: String, \n  producto: String, \n  unidades: Int, \n  precioUnitario: Double, \n  ciudad: String\n)\n\n// 2. Define la estructura de salida esperada\ncase class VentaOnlineProcesada(\n  idPedido: Int,\n  cliente: String,\n  canal: String,\n  producto: String,\n  unidades: Int,\n  precioUnitario: Double,\n  ciudad: String,\n  importeTotal: Double,\n  segmentoPedido: String\n)\n\n// 3. Convierte el DataFrame filtrado a un Dataset tipado\nval dsTipado \u003d dsPedidosValidos.as[VentaOnline]\n\n// 4. Procesa fila por fila aplicando la lógica de negocio\nval dsPedidosProcesados \u003d dsTipado.map { pedido \u003d\u003e\n  val importeTotal \u003d pedido.unidades * pedido.precioUnitario\n  \n  // Lógica para determinar el segmento según los datos de tu imagen\n  val segmento \u003d if (importeTotal \u003e 500) {\n    \&quot;ALTO_VALOR\&quot;\n  } else if (importeTotal \u003e\u003d 150) {\n    \&quot;VALOR_MEDIO\&quot;\n  } else {\n    \&quot;BAJO_VALOR\&quot;\n  }\n\n  VentaOnlineProcesada(\n    pedido.idPedido,\n    pedido.cliente,\n    pedido.canal,\n    pedido.producto,\n    pedido.unidades,\n    pedido.precioUnitario,\n    pedido.ciudad,\n    importeTotal,\n    segmento\n  )\n}\n\n// 5. Imprime el resultado final\ndsPedidosProcesados.show(false)\n&quot;,[[&quot;import&quot;,3],[&quot; spark.implicits._\n\n&quot;,0],[&quot;// 1. Define la estructura de entrada&quot;,5],[&quot;\n&quot;,0],[&quot;case&quot;,3],[&quot; &quot;,0],[&quot;class&quot;,3],[&quot; VentaOnline(\n  idPedido: Int, \n  cliente: String, \n  canal: String, \n  producto: String, \n  unidades: Int, \n  precioUnitario: Double, \n  ciudad: String\n)\n\n&quot;,0],[&quot;// 2. Define la estructura de salida esperada&quot;,5],[&quot;\n&quot;,0],[&quot;case&quot;,3],[&quot; &quot;,0],[&quot;class&quot;,3],[&quot; VentaOnlineProcesada(\n  idPedido: Int,\n  cliente: String,\n  canal: String,\