)

</span><span class="ClTQqc">// 2. Convertimos a DATASET y filtramos (Seguridad de tipos)</span><span class="undefined">
</span><span class="mexSqb">val</span><span class="undefined"> dsAltoValor = pipelineFinalPedidos
