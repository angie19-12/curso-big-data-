</span><span class="mexSqb">import</span><span class="undefined"> spark.implicits._

</span><span class="ClTQqc">// 1. Necesitamos la plantilla para que Spark entienda el Dataset</span><span class="undefined">
</span><span class="mexSqb">case</span><span class="undefined"> </span><span class="mexSqb">class</span><span class="undefined"> VentaOnlineProcesada(
